<?xml version="1.0" encoding="utf-8"?>
<!-- Microsoft Store package manifest for CertConvert. Identity values come from
     Partner Center → Product Identity and must match exactly, or upload is
     rejected. Version's fourth part must stay 0 for Store submissions;
     build/make-msix.ps1 stamps the first three from the .csproj. -->
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="uap rescap">

  <Identity
    Name="JermaineWalkes.CertConvert"
    Publisher="CN=2F7BAB54-DD4D-405B-A67E-4539A9971265"
    Version="1.1.0.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>CertConvert</DisplayName>
    <PublisherDisplayName>Jermaine Walkes</PublisherDisplayName>
    <Logo>assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-gb" />
  </Resources>

  <Applications>
    <Application Id="CertConvert" Executable="CertConvert.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="CertConvert"
        Description="Convert, chain, inspect and generate X.509 certificates offline — PEM, DER, PKCS #7 and PKCS #12, no OpenSSL required."
        BackgroundColor="transparent"
        Square150x150Logo="assets\Square150x150Logo.png"
        Square44x44Logo="assets\Square44x44Logo.png">
        <uap:DefaultTile
          Wide310x150Logo="assets\Wide310x150Logo.png"
          Square310x310Logo="assets\Square310x310Logo.png"
          Square71x71Logo="assets\Square71x71Logo.png">
          <uap:ShowNameOnTiles>
            <uap:ShowOn Tile="square150x150Logo" />
            <uap:ShowOn Tile="wide310x150Logo" />
          </uap:ShowNameOnTiles>
        </uap:DefaultTile>
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
