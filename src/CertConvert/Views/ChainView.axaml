<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CertConvert.ViewModels"
             x:Class="CertConvert.Views.ChainView"
             x:DataType="vm:ChainViewModel">
  <ScrollViewer>
    <StackPanel Margin="32,40,32,24" Spacing="14" MaxWidth="920">

      <StackPanel Spacing="4" Margin="0,0,0,4">
        <TextBlock Classes="pageTitle" Text="Chain"/>
        <TextBlock Classes="pageSub"
                   Text="Order root, intermediate and device certificates, validate the chain offline and export it."/>
      </StackPanel>

      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section" Text="Certificates"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Add Certificates…" Command="{Binding AddFilesCommand}"/>
            <Button Content="Remove Selected" Command="{Binding RemoveSelectedCommand}"/>
            <Button Content="Clear" Command="{Binding ClearFilesCommand}"/>
            <TextBox Width="210" PlaceholderText="Input Password (If Needed)" PasswordChar="•"
                     Text="{Binding Password}"
                     AutomationProperties.Name="Password for encrypted input files"/>
          </StackPanel>
          <ListBox Classes="files" MinHeight="100" MaxHeight="200"
                   ItemsSource="{Binding InputFiles}"
                   SelectedItem="{Binding SelectedInput}"
                   AutomationProperties.Name="Chain certificate files"/>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section" Text="Validation"/>
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Content="Validate Chain" Classes="accent" Command="{Binding ValidateChainCommand}"/>
            <CheckBox Content="Trust System Roots" IsChecked="{Binding TrustSystemRoots}"/>
          </StackPanel>

          <ItemsControl ItemsSource="{Binding Results}"
                        AutomationProperties.Name="Validation results">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ChainRow">
                <StackPanel Margin="0,3">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Classes="pillOk" IsVisible="{Binding !HasIssues}">
                      <TextBlock Text="OK"/>
                    </Border>
                    <Border Classes="pillFail" IsVisible="{Binding HasIssues}">
                      <TextBlock Text="FAIL"/>
                    </Border>
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                  </StackPanel>
                  <TextBlock Text="{Binding Issues}" Margin="52,2,0,0" TextWrapping="Wrap"
                             Classes="secondary" FontSize="12"
                             IsVisible="{Binding HasIssues}"/>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Text="{Binding Verdict}" FontWeight="SemiBold"
                     IsVisible="{Binding Verdict.Length}" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section" Text="Export"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <ComboBox MinWidth="230" ItemsSource="{Binding ExportFormats}"
                      SelectedItem="{Binding SelectedExportFormat}"
                      AutomationProperties.Name="Chain export format"/>
            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsPfx}">
              <Button Content="Add Key File…" Command="{Binding PickKeyFileCommand}"/>
              <TextBox Width="150" PlaceholderText="Key Password" PasswordChar="•"
                       Text="{Binding KeyPassword}"
                       AutomationProperties.Name="Password for the key file"/>
              <TextBox Width="150" PlaceholderText="PFX Password" PasswordChar="•"
                       Text="{Binding OutPassword}"
                       AutomationProperties.Name="Password for the new PFX file"/>
            </StackPanel>
            <Button Content="Export Chain…" Classes="accent" Command="{Binding ExportChainCommand}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <TextBlock Classes="status" Text="{Binding Status}" TextWrapping="Wrap"
                 AutomationProperties.LiveSetting="Polite"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
