<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CertConvert.ViewModels"
             x:Class="CertConvert.Views.KeysView"
             x:DataType="vm:KeysViewModel">
  <ScrollViewer>
    <StackPanel Margin="32,40,32,24" Spacing="14" MaxWidth="920">

      <StackPanel Spacing="4" Margin="0,0,0,4">
        <TextBlock Classes="pageTitle" Text="Keys"/>
        <TextBlock Classes="pageSub"
                   Text="Re-encode private keys and check whether a key belongs to a certificate."/>
      </StackPanel>

      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section" Text="Private key"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Open Key…" Classes="accent" Command="{Binding OpenKeyCommand}"/>
            <TextBox Width="210" PlaceholderText="Key Password (If Needed)" PasswordChar="•"
                     Text="{Binding Password}"
                     AutomationProperties.Name="Password for the key file"/>
            <Button Content="Unlock" Command="{Binding LoadKeyCommand}"
                    AutomationProperties.HelpText="Reload the key using the password"/>
            <TextBlock Text="{Binding KeyDescription}" VerticalAlignment="Center" FontWeight="SemiBold"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section" Text="Convert format"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <ComboBox MinWidth="280" ItemsSource="{Binding Formats}"
                      SelectedItem="{Binding SelectedFormat}"
                      AutomationProperties.Name="Key output format"/>
            <TextBox Width="180" PlaceholderText="New Password" PasswordChar="•"
                     Text="{Binding OutPassword}" IsVisible="{Binding NeedsOutPassword}"
                     AutomationProperties.Name="Password for the converted key"/>
            <Button Content="Save Converted Key…" Command="{Binding SaveConvertedCommand}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section" Text="Does this key match a certificate?"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Choose Certificate…" Command="{Binding PickCertCommand}"/>
            <TextBlock Text="{Binding CertFile}" VerticalAlignment="Center" MaxWidth="300"
                       TextTrimming="CharacterEllipsis" Classes="secondary"/>
            <Button Content="Check Match" Command="{Binding CheckMatchCommand}"/>
          </StackPanel>
          <TextBlock Text="{Binding MatchResult}" FontWeight="SemiBold"
                     IsVisible="{Binding MatchResult.Length}"/>
        </StackPanel>
      </Border>

      <TextBlock Classes="status" Text="{Binding Status}" TextWrapping="Wrap"
                 IsVisible="{Binding Status.Length}"
                 AutomationProperties.LiveSetting="Polite"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
