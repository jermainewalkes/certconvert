<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CertConvert.ViewModels"
             x:Class="CertConvert.Views.ConvertView"
             x:DataType="vm:ConvertViewModel">
  <Grid RowDefinitions="Auto,*,Auto,Auto,Auto" Margin="16" RowSpacing="12">

    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
      <Button Content="Add Files…" Command="{Binding AddFilesCommand}"/>
      <Button Content="Remove Selected" Command="{Binding RemoveSelectedCommand}"/>
      <Button Content="Clear" Command="{Binding ClearFilesCommand}"/>
      <TextBox Width="200" PlaceholderText="Input Password (If Needed)" PasswordChar="•"
               Text="{Binding Password}"
               AutomationProperties.Name="Password for encrypted input files"/>
    </StackPanel>

    <ListBox Grid.Row="1" ItemsSource="{Binding InputFiles}"
             SelectedItem="{Binding SelectedInput}"
             AutomationProperties.Name="Input files"/>

    <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
      <TextBlock Grid.Column="0" Text="Target format" VerticalAlignment="Center"/>
      <ComboBox Grid.Column="1" MaxWidth="320" HorizontalAlignment="Left"
                ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat}"
                AutomationProperties.Name="Target format"/>
      <Button Grid.Column="2" Content="Convert And Save…" Command="{Binding ConvertAndSaveCommand}"
              Classes="accent"/>
    </Grid>

    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8"
                IsVisible="{Binding IsPfx}">
      <Button Content="Add Key File…" Command="{Binding PickKeyFileCommand}"/>
      <TextBlock Text="{Binding KeyFile}" VerticalAlignment="Center" MaxWidth="260"
                 TextTrimming="CharacterEllipsis"/>
      <TextBox Width="170" PlaceholderText="Key Password" PasswordChar="•"
               Text="{Binding KeyPassword}"
               AutomationProperties.Name="Password for the key file"/>
      <TextBox Width="170" PlaceholderText="PFX Password" PasswordChar="•"
               Text="{Binding OutPassword}"
               AutomationProperties.Name="Password for the new PFX file"/>
      <CheckBox Content="Legacy Ciphers (Old Importers)" IsChecked="{Binding LegacyCiphers}"/>
    </StackPanel>

    <TextBlock Grid.Row="4" Text="{Binding Status}" TextWrapping="Wrap"
               AutomationProperties.LiveSetting="Polite"/>
  </Grid>
</UserControl>
