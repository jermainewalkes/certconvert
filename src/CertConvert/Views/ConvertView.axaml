<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CertConvert.ViewModels"
             x:Class="CertConvert.Views.ConvertView"
             x:DataType="vm:ConvertViewModel"
             DragDrop.AllowDrop="True">
  <ScrollViewer>
    <StackPanel Margin="32,40,32,24" Spacing="14" MaxWidth="920">

      <StackPanel Spacing="4" Margin="0,0,0,4">
        <TextBlock Classes="pageTitle" Text="Convert"/>
        <TextBlock Classes="pageSub"
                   Text="Re-encode certificates between PEM, DER, PKCS #7 and PKCS #12."/>
      </StackPanel>

      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section" Text="Input files"/>
          <WrapPanel Classes="toolbar">
            <Button Content="Add Files…" Command="{Binding AddFilesCommand}"/>
            <Button Content="Remove Selected" Command="{Binding RemoveSelectedCommand}"/>
            <Button Content="Clear" Command="{Binding ClearFilesCommand}"/>
            <TextBox Width="210" PlaceholderText="Input Password (If Needed)" PasswordChar="•"
                     Text="{Binding Password}"
                     AutomationProperties.Name="Password for encrypted input files"/>
          </WrapPanel>
          <Panel MinHeight="150" IsVisible="{Binding !InputFiles.Count}">
            <Rectangle Stroke="{DynamicResource AppCardBorder}" StrokeThickness="1.5"
                       StrokeDashArray="4,3" RadiusX="10" RadiusY="10" Fill="Transparent"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
              <PathIcon Data="{StaticResource IconConvert}" Width="26" Height="26"
                        Foreground="{DynamicResource AppTextSecondary}"
                        HorizontalAlignment="Center"/>
              <TextBlock Text="Drag and drop files here"
                         FontWeight="SemiBold" HorizontalAlignment="Center"/>
              <TextBlock Classes="secondary" FontSize="12" HorizontalAlignment="Center"
                         Text="Or use Add Files… — certificates, bundles and keys all work"/>
            </StackPanel>
          </Panel>
          <ListBox Classes="files" MinHeight="120" MaxHeight="220"
                   IsVisible="{Binding InputFiles.Count}"
                   ItemsSource="{Binding InputFiles}"
                   SelectedItem="{Binding SelectedInput}"
                   AutomationProperties.Name="Input files"/>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section" Text="Output"/>
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="Target format" VerticalAlignment="Center" Classes="secondary"/>
            <ComboBox MinWidth="240" ItemsSource="{Binding Formats}"
                      SelectedItem="{Binding SelectedFormat}"
                      AutomationProperties.Name="Target format"/>
          </StackPanel>

          <WrapPanel Classes="toolbar" IsVisible="{Binding IsPfx}">
            <Button Content="Add Key File…" Command="{Binding PickKeyFileCommand}"/>
            <TextBlock Text="{Binding KeyFile}" MaxWidth="230"
                       TextTrimming="CharacterEllipsis" Classes="secondary"/>
            <TextBox Width="160" PlaceholderText="Key Password" PasswordChar="•"
                     Text="{Binding KeyPassword}"
                     AutomationProperties.Name="Password for the key file"/>
            <TextBox Width="160" PlaceholderText="PFX Password" PasswordChar="•"
                     Text="{Binding OutPassword}"
                     AutomationProperties.Name="Password for the new PFX file"/>
            <CheckBox Content="Legacy Ciphers (Old Importers)" IsChecked="{Binding LegacyCiphers}"/>
          </WrapPanel>

          <Button Content="Convert And Save…" Classes="accent" HorizontalAlignment="Left"
                  Command="{Binding ConvertAndSaveCommand}"/>
        </StackPanel>
      </Border>

      <TextBlock Classes="status" Text="{Binding Status}" TextWrapping="Wrap"
                 IsVisible="{Binding Status.Length}"
                 AutomationProperties.LiveSetting="Polite"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
