<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CertConvert.ViewModels"
        xmlns:views="using:CertConvert.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="CertConvert.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1000" Height="700" MinWidth="820" MinHeight="560"
        Title="CertConvert">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <TabControl Margin="4">
        <TabItem Header="Inspect">
            <views:InspectView DataContext="{Binding Inspect}"/>
        </TabItem>
        <TabItem Header="Convert">
            <views:ConvertView DataContext="{Binding Convert}"/>
        </TabItem>
        <TabItem Header="Chain">
            <views:ChainView DataContext="{Binding Chain}"/>
        </TabItem>
        <TabItem Header="Keys">
            <views:KeysView DataContext="{Binding Keys}"/>
        </TabItem>
        <TabItem Header="Generate">
            <views:GenerateView DataContext="{Binding Generate}"/>
        </TabItem>
        <TabItem Header="About">
            <views:AboutView DataContext="{Binding About}"/>
        </TabItem>
    </TabControl>
</Window>
