<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CertConvert.ViewModels"
             x:Class="CertConvert.Views.GenerateView"
             x:DataType="vm:GenerateViewModel">
  <ScrollViewer>
    <StackPanel Margin="32,40,32,24" Spacing="14" MaxWidth="920">

      <StackPanel Spacing="4" Margin="0,0,0,4">
        <TextBlock Classes="pageTitle" Text="Generate"/>
        <TextBlock Classes="pageSub"
                   Text="Create keys, certificate signing requests and self-signed certificates."/>
      </StackPanel>

      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section" Text="Key"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <ComboBox MinWidth="180" ItemsSource="{Binding Algorithms}"
                      SelectedItem="{Binding SelectedAlgorithm}"
                      AutomationProperties.Name="Key algorithm"/>
            <TextBox Width="200" PlaceholderText="Key Password (Optional)" PasswordChar="•"
                     Text="{Binding KeyPassword}"
                     AutomationProperties.Name="Password to encrypt the key file, also used when loading"/>
            <Button Content="Generate Key And Save…" Command="{Binding GenerateKeyAndSaveCommand}"/>
            <Button Content="Load Existing Key…" Command="{Binding LoadExistingKeyCommand}"/>
            <TextBlock Text="{Binding KeyDescription}" VerticalAlignment="Center" FontWeight="SemiBold"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section" Text="Subject"/>
          <Grid ColumnDefinitions="190,320" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                RowSpacing="10" ColumnSpacing="10">
            <TextBlock Grid.Row="0" Classes="secondary" Text="Common name (CN) *" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CommonName}"
                     PlaceholderText="device.example.com"
                     AutomationProperties.Name="Common name"/>
            <TextBlock Grid.Row="1" Classes="secondary" Text="Organisation (O)" VerticalAlignment="Center"/>
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Organization}"
                     AutomationProperties.Name="Organisation"/>
            <TextBlock Grid.Row="2" Classes="secondary" Text="Unit (OU)" VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding OrganizationalUnit}"
                     AutomationProperties.Name="Organisational unit"/>
            <TextBlock Grid.Row="3" Classes="secondary" Text="Country (two letters)" VerticalAlignment="Center"/>
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Country}" PlaceholderText="GB"
                     AutomationProperties.Name="Country code"/>
            <TextBlock Grid.Row="4" Classes="secondary" Text="State or county" VerticalAlignment="Center"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding State}"
                     AutomationProperties.Name="State or county"/>
            <TextBlock Grid.Row="5" Classes="secondary" Text="Locality" VerticalAlignment="Center"/>
            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Locality}"
                     AutomationProperties.Name="Locality"/>
          </Grid>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section" Text="Names and options"/>
          <Grid ColumnDefinitions="190,320" RowDefinitions="Auto,Auto,Auto,Auto"
                RowSpacing="10" ColumnSpacing="10">
            <TextBlock Grid.Row="0" Classes="secondary" Text="DNS names (comma-separated)"
                       VerticalAlignment="Center" TextWrapping="Wrap"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DnsNames}"
                     PlaceholderText="a.example.com, b.example.com"
                     AutomationProperties.Name="DNS subject alternative names"/>
            <TextBlock Grid.Row="1" Classes="secondary" Text="IP addresses (comma-separated)"
                       VerticalAlignment="Center" TextWrapping="Wrap"/>
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding IpAddresses}"
                     PlaceholderText="10.0.0.36"
                     AutomationProperties.Name="IP subject alternative names"/>
            <TextBlock Grid.Row="2" Classes="secondary" Text="Validity (days)" VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ValidityDays}"
                     AutomationProperties.Name="Validity in days"/>
            <CheckBox Grid.Row="3" Grid.ColumnSpan="2" Content="Certificate Authority (CA)"
                      IsChecked="{Binding IsCa}"/>
          </Grid>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Save CSR…" Command="{Binding SaveCsrCommand}"
                    IsEnabled="{Binding HasKey}" Classes="accent"/>
            <Button Content="Save Self-Signed Certificate…" Command="{Binding SaveSelfSignedCommand}"
                    IsEnabled="{Binding HasKey}" Classes="accent"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <TextBlock Classes="status" Text="{Binding Status}" TextWrapping="Wrap"
                 AutomationProperties.LiveSetting="Polite"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
