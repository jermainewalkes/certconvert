<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CertConvert.ViewModels"
             x:Class="CertConvert.Views.AboutView"
             x:DataType="vm:AboutViewModel">
  <ScrollViewer>
    <StackPanel Margin="32,40,32,24" Spacing="14" MaxWidth="680" HorizontalAlignment="Left">

      <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,0,0,4">
        <Image Source="avares://CertConvert/Assets/icon-256.png" Width="56" Height="56"/>
        <StackPanel VerticalAlignment="Center" Spacing="2">
          <TextBlock Classes="pageTitle" Text="CertConvert"/>
          <TextBlock Classes="pageSub" Text="{Binding Version}"/>
        </StackPanel>
      </StackPanel>

      <TextBlock TextWrapping="Wrap" Classes="secondary"
                 Text="Convert, chain, inspect and generate certificates without installing openssl. PEM, DER (.cer), PKCS #7 (.p7b) and PKCS #12 (.pfx/.p12) are supported in both directions."/>

      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Classes="section" Text="Updates"/>
          <WrapPanel Classes="toolbar">
            <Button Content="Check For Updates" Command="{Binding CheckForUpdatesCommand}"/>
            <CheckBox Content="Check For Updates On Launch" IsChecked="{Binding CheckOnLaunch}"
                      AutomationProperties.HelpText="When enabled, CertConvert contacts GitHub once at startup to look for a newer version"/>
          </WrapPanel>
          <TextBlock Classes="status" Text="{Binding UpdateStatus}" TextWrapping="Wrap"
                     IsVisible="{Binding UpdateStatus.Length}"
                     AutomationProperties.LiveSetting="Polite"/>
          <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsDownloading}">
            <ProgressBar Minimum="0" Maximum="1" Value="{Binding DownloadProgress}"
                         Width="240" VerticalAlignment="Center"
                         AutomationProperties.Name="Download progress"/>
            <Button Content="Cancel" Command="{Binding CancelDownloadCommand}"
                    IsVisible="{Binding CanCancel}"/>
          </StackPanel>
          <WrapPanel Classes="toolbar">
            <Button Content="Download And Install…" Classes="accent"
                    Command="{Binding DownloadAndInstallCommand}" IsVisible="{Binding CanInstall}"/>
            <Button Content="View Release Notes"
                    Command="{Binding ViewReleaseNotesCommand}" IsVisible="{Binding UpdateAvailable}"/>
            <Button Content="Restart Now" Classes="accent"
                    Command="{Binding RestartNowCommand}" IsVisible="{Binding CanRestart}"/>
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="8">
          <TextBlock Classes="section" Text="Security"/>
          <TextBlock TextWrapping="Wrap" Text="{Binding SecurityStatement}"/>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="8">
          <TextBlock Classes="section" Text="Command line"/>
          <TextBlock TextWrapping="Wrap" Text="{Binding CliHint}"/>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="8">
          <TextBlock Classes="section" Text="Accessibility"/>
          <TextBlock TextWrapping="Wrap" Text="{Binding AccessibilityStatement}"/>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Classes="section" Text="Support"/>
          <TextBlock TextWrapping="Wrap"
                     Text="CertConvert is free and open source (MIT licence). If it saves you time, a coffee is always appreciated."/>
          <Button Content="Buy Me A Coffee On Ko-fi" Command="{Binding OpenKoFiCommand}"
                  Classes="accent" HorizontalAlignment="Left"
                  AutomationProperties.HelpText="Opens the Ko-fi donation page in your browser"/>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
